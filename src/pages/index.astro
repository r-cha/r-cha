---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import SiteHeader from "../components/SiteHeader.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

const posts: CollectionEntry<"blog">[] = (await getCollection("blog"))
  .filter((post) => post.data.isVisible)
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  )
  .slice(0, 5);

const featuredProjects = [
  {
    name: "Shed",
    url: "https://shed.concerto.studio/",
    avif: "/images/avif/shed.avif",
    webp: "/images/webp/shed.webp",
    fallback: "/images/shed.png",
    width: 800,
    height: 487,
  },
  {
    name: "Birren Colors",
    url: "https://birren.vercel.app/",
    avif: "/images/avif/birren.avif",
    webp: "/images/webp/birren.webp",
    fallback: "/images/birren.png",
    width: 400,
    height: 210,
  },
];
---

<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body
    class="my-8 mx-4"
    style="background-color: var(--color-bg); color: var(--color-text);"
  >
    <SiteHeader />
    <main class="w-full max-w-prose mx-auto">
      <p class="mb-8 leading-relaxed" style="color: var(--color-text-muted);">
        Software engineer, musician, and follower of Jesus.
        I build software, play drums, and write about what I learn along the way.{" "}
         <a
          href="/about/"
          class="hover:underline whitespace-nowrap"
          style="color: var(--color-accent);"
          data-astro-prefetch>More about me &rarr;</a
        >       <a
          href="/blog/statement-of-faith/"
          class="hover:underline whitespace-nowrap"
          style="color: var(--color-accent);"
          data-astro-prefetch>Statement of faith &rarr;</a
        >
      </p>

      <div class="grid gap-8 md:grid-cols-[1fr_210px]">
        <!-- Writing -->
        <section>
          <h2
            class="flex items-baseline justify-between pb-2 mb-4"
            style="font-family: var(--font-serif); font-weight: 600; line-height: 1.2; border-bottom: 1px solid var(--color-border);"
          >
            <span class="text-xl">Writing</span>
            <a
              href="/blog/ai-usage/"
              class="text-xs font-light hover:underline"
              style="color: var(--color-text-muted);"
              data-astro-prefetch>ai policy</a
            >
          </h2>
          <dl>
            {
              posts.map((post) => (
                <div class="pb-3">
                  <a
                    href={`/blog/${post.id}/`}
                    class="flex flew-row text-decoration group"
                    data-astro-prefetch
                  >
                    <dt
                      class="tracking-tight float-left z-10 text-left group-hover:underline transition-colors duration-200"
                      style="background-color: var(--color-bg); color: var(--color-text); font-family: var(--font-serif); font-weight: 500;"
                    >
                      {post.data.title}
                    </dt>
                    <span class="w-0 sm:w-auto float-left grow whitespace-nowrap" />
                    <dd
                      class="self-start font-mono tracking-tighter font-light float-right text-nowrap text-right group-hover:underline transition-colors duration-200"
                      style="background-color: var(--color-bg); color: var(--color-text-muted);"
                    >
                      <FormattedDate date={post.data.pubDate} />
                    </dd>
                  </a>
                  {post.data.description && (
                    <p
                      class="ml-2 text-left text-xs font-light leading-relaxed"
                      style="color: var(--color-text-muted);"
                    >
                      {post.data.description}
                    </p>
                  )}
                </div>
              ))
            }
            <a
              href="/blog"
              class="inline-block mt-2 font-mono text-sm hover:underline"
              style="color: var(--color-accent);"
              data-astro-prefetch>See all &rarr;</a
            >
          </dl>
        </section>

        <!-- Projects -->
        <section>
          <h2
            class="text-xl pb-2 mb-4"
            style="font-family: var(--font-serif); font-weight: 600; line-height: 1.2; border-bottom: 1px solid var(--color-border);"
          >
            Projects
          </h2>
          <div class="flex flex-col gap-3">
            {
              featuredProjects.map((project) => (
                <article
                  class="group rounded-lg overflow-hidden shadow-lg transition-all duration-300 hover:shadow-xl hover:scale-[1.02]"
                  style="background-color: var(--color-bg); border: 1px solid var(--color-border);"
                >
                  <a href={project.url} target="_blank" data-astro-prefetch>
                    <div class="overflow-hidden aspect-[16/9]">
                      <picture>
                        <source srcset={project.avif} type="image/avif" />
                        <source srcset={project.webp} type="image/webp" />
                        <img
                          src={project.fallback}
                          alt={project.name}
                          width={project.width}
                          height={project.height}
                          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                        />
                      </picture>
                    </div>
                    <div class="p-2">
                      <span
                        class="tracking-tight group-hover:underline transition-colors duration-200"
                        style="background-color: var(--color-bg); color: var(--color-text); font-family: var(--font-serif); font-weight: 500;"
                      >
                        {project.name}
                      </span>
                    </div>
                  </a>
                </article>
              ))
            }
          </div>
          <a
            href="/projects"
            class="inline-block mt-3 font-mono text-sm hover:underline"
            style="color: var(--color-accent);"
            data-astro-prefetch>See all &rarr;</a
          >
        </section>
      </div>
    </main>
  </body>
</html>
